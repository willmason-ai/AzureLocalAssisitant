# Dashboard Authentication
DASHBOARD_PASSWORD=your-dashboard-password
JWT_SECRET=generate-a-random-string-here

# Credential Encryption
CREDENTIAL_MASTER_KEY=generate-a-strong-master-key

# Claude API
ANTHROPIC_API_KEY=sk-ant-api-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Azure Local Connection
AZURELOCAL_NODE1=dell-as01.presidiorocks.com
AZURELOCAL_NODE2=dell-as02.presidiorocks.com
AZURELOCAL_DOMAIN=presidiorocks.com
AZURELOCAL_CLUSTER=azurestack01
AZURELOCAL_USERNAME=hciadmin
AZURELOCAL_PASSWORD=your-cluster-password

# WinRM Configuration
WINRM_TRANSPORT=ntlm
WINRM_USE_SSL=true
SSH_FALLBACK_ENABLED=true

# Azure (for Azure API/CLI calls)
AZURE_SUBSCRIPTION_ID=aaaaa147-fd6e-48fb-9a66-d044700dca17
AZURE_RESOURCE_GROUP=rg-azurestack
AZURE_TENANT_ID=2a731c61-a2b2-4661-8409-5b861cf40d0c

# Azure SPN (for Extensions page — create via: az ad sp create-for-rbac --role Reader --scopes /subscriptions/.../resourceGroups/rg-azurestack)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# App
PORT=5230

# Scheduler Intervals (seconds)
HEALTH_CHECK_INTERVAL=60
CREDENTIAL_CHECK_INTERVAL=21600
CVE_CHECK_INTERVAL=86400
